{
  "name": "@zanichelli/albe-snowflakes",
  "version": "0.0.1-PACK1",
  "description": "The Zanichelli design system snowflakes components.",
  "license": "MIT",
  "main": "dist/index.cjs.js",
  "unpkg": "dist/web-components-library/web-components-library.esm.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist/",
    "loader/",
    "www/",
    "react/"
  ],
  "scripts": {
    "build": "yarn build.wc && yarn build.react",
    "build.react": "rimraf react && tsc --build tsconfig.react.json",
    "build.wc": "mkdirp react && rimraf src-react/react-component-lib && stencil build",
    "start": "stencil build --dev --watch --serve --no-open"
  },
  "devDependencies": {
    "@commitlint/cli": "^12.0.0",
    "@commitlint/config-conventional": "^12.0.0",
    "@eslint/js": "^9.39.1",
    "@rollup/plugin-image": "^3.0.3",
    "@stencil/core": "~4.43.3",
    "@stencil/eslint-plugin": "^1.1.0",
    "@stencil/react-output-target": "^0.5.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "commit-and-tag-version": "^12.4.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^8.0.0",
    "mkdirp": "^3.0.1",
    "plop": "^4.0.1",
    "prettier": "^3.5.0",
    "prettier-plugin-organize-imports": "^3.2.4",
    "rimraf": "^6.0.1",
    "stylelint": "^14.9.1",
    "stylelint-config-idiomatic-order": "^8.1.0",
    "stylelint-config-prettier": "^9.0.3",
    "stylelint-config-standard": "^26.0.0",
    "stylelint-value-no-unknown-custom-properties": "^4.0.0",
    "typescript": "~5.4.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.9"
  },
  "peerDependencies": {
    "react": "*",
    "react-dom": "*"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "resolutions": {
    "@stencil/core": "~4.43.3"
  },
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "packageManager": "yarn@4.10.3"
}
