{
    "env": {
        "browser": true,
        "es2021": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended",
        "prettier"
    ],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "ecmaVersion": 12,
        "sourceType": "module"
    },
    "plugins": [
        "@typescript-eslint"
    ],
    "rules": {
      "@typescript-eslint/no-unused-vars":[
        "warn",
        {"varsIgnorePattern": "h"}
      ],
      "@typescript-eslint/no-inferrable-types": [
        "warn"
      ],
      "@typescript-eslint/ban-ts-comment": [
        "warn"
      ]
    }
}
